# =====================================================
# Brandmaster — переменные окружения
# Скопируй этот файл в .env и впиши настоящие ключи.
# .env НЕ коммитится в git (см. .gitignore).
# =====================================================

# Anthropic — для AI-прокси на /api/ai
# Получить ключ: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Supabase — для авторизации и базы
# Получить значения: https://supabase.com/dashboard → Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
# Service-role ключ ОБЯЗАТЕЛЬНО держать только на бэке, никогда не отдавать клиенту
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Сервер
PORT=3000
NODE_ENV=development
